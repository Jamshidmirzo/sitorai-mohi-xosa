generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== EXHIBITS ====================

model Category {
  id           String                @id @default(cuid())
  slug         String                @unique
  createdAt    DateTime              @default(now())
  translations CategoryTranslation[]
  exhibits     Exhibit[]
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  locale     String
  name       String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model Hall {
  id           String            @id @default(cuid())
  slug         String            @unique
  number       Int?
  createdAt    DateTime          @default(now())
  translations HallTranslation[]
  exhibits     Exhibit[]
}

model HallTranslation {
  id          String @id @default(cuid())
  hallId      String
  locale      String
  name        String
  description String?
  hall        Hall   @relation(fields: [hallId], references: [id], onDelete: Cascade)

  @@unique([hallId, locale])
}

model Exhibit {
  id           String               @id @default(cuid())
  slug         String               @unique
  categoryId   String?
  hallId       String?
  period       String?
  material     String?
  featured     Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  hall         Hall?                @relation(fields: [hallId], references: [id], onDelete: SetNull)
  translations ExhibitTranslation[]
  images       ExhibitImage[]
  surveys      Survey[]
  responses    SurveyResponse[]
}

model ExhibitTranslation {
  id          String  @id @default(cuid())
  exhibitId   String
  locale      String
  name        String
  description String? @db.Text
  exhibit     Exhibit @relation(fields: [exhibitId], references: [id], onDelete: Cascade)

  @@unique([exhibitId, locale])
}

model ExhibitImage {
  id        String  @id @default(cuid())
  exhibitId String
  url       String
  alt       String?
  order     Int     @default(0)
  exhibit   Exhibit @relation(fields: [exhibitId], references: [id], onDelete: Cascade)
}

// ==================== POSTS / NEWS ====================

model Post {
  id           String            @id @default(cuid())
  slug         String            @unique
  coverImage   String?
  published    Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  translations PostTranslation[]
}

model PostTranslation {
  id      String  @id @default(cuid())
  postId  String
  locale  String
  title   String
  excerpt String? @db.Text
  content String? @db.Text
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

// ==================== GALLERY ====================

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ==================== SURVEYS ====================

model Survey {
  id           String              @id @default(cuid())
  exhibitId    String?
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  exhibit      Exhibit?            @relation(fields: [exhibitId], references: [id], onDelete: SetNull)
  translations SurveyTranslation[]
  questions    SurveyQuestion[]
  responses    SurveyResponse[]
}

model SurveyTranslation {
  id          String  @id @default(cuid())
  surveyId    String
  locale      String
  title       String
  description String? @db.Text
  survey      Survey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, locale])
}

model SurveyQuestion {
  id           String                 @id @default(cuid())
  surveyId     String
  type         String
  order        Int                    @default(0)
  required     Boolean                @default(false)
  survey       Survey                 @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  translations QuestionTranslation[]
  options      QuestionOption[]
  answers      ResponseAnswer[]
}

model QuestionTranslation {
  id         String         @id @default(cuid())
  questionId String
  locale     String
  text       String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, locale])
}

model QuestionOption {
  id           String              @id @default(cuid())
  questionId   String
  order        Int                 @default(0)
  question     SurveyQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  translations OptionTranslation[]
  answers      ResponseAnswer[]
}

model OptionTranslation {
  id       String         @id @default(cuid())
  optionId String
  locale   String
  text     String
  option   QuestionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, locale])
}

model SurveyResponse {
  id        String           @id @default(cuid())
  surveyId  String
  exhibitId String?
  sessionId String
  locale    String
  createdAt DateTime         @default(now())
  survey    Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  exhibit   Exhibit?         @relation(fields: [exhibitId], references: [id], onDelete: SetNull)
  answers   ResponseAnswer[]
}

model ResponseAnswer {
  id          String          @id @default(cuid())
  responseId  String
  questionId  String
  optionId    String?
  textValue   String?         @db.Text
  ratingValue Int?
  response    SurveyResponse  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question    SurveyQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option      QuestionOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
}

// ==================== VISITOR INFO ====================

model VisitorInfo {
  id          String  @id @default(cuid())
  locale      String  @unique
  hours       String? @db.Text
  ticketPrices String? @db.Text
  address     String?
  phone       String?
  email       String?
  mapEmbedUrl String?
}

// ==================== SITE SETTINGS ====================

model SiteSettings {
  id              String  @id @default(cuid())
  locale          String  @unique
  siteName        String?
  siteDescription String? @db.Text
  heroTitle       String?
  heroSubtitle    String?
  heroImage       String?
  aboutText       String? @db.Text
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== EXHIBITS ====================

model Category {
  id           String                @id @default(cuid())
  slug         String                @unique
  createdAt    DateTime              @default(now())
  translations CategoryTranslation[]
  exhibits     Exhibit[]
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String
  locale     String
  name       String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model Hall {
  id           String            @id @default(cuid())
  slug         String            @unique
  number       Int?
  createdAt    DateTime          @default(now())
  translations HallTranslation[]
  exhibits     Exhibit[]
}

model HallTranslation {
  id          String @id @default(cuid())
  hallId      String
  locale      String
  name        String
  description String?
  hall        Hall   @relation(fields: [hallId], references: [id], onDelete: Cascade)

  @@unique([hallId, locale])
}

model Exhibit {
  id            String               @id @default(cuid())
  slug          String               @unique
  categoryId    String?
  hallId        String?
  period        String?
  material      String?
  /// CSS gradient or color hex used as the card background placeholder.
  bg            String?
  /// Short placeholder caption like "[ robe · gold embroidery ]".
  shot          String?
  /// Display order on the Collection rail (0 = first).
  order         Int                  @default(0)
  featured      Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  category      Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  hall          Hall?                @relation(fields: [hallId], references: [id], onDelete: SetNull)
  translations  ExhibitTranslation[]
  images        ExhibitImage[]
  surveys       Survey[]
  responses     SurveyResponse[]
  quizQuestions QuizQuestion[]
}

model ExhibitTranslation {
  id          String  @id @default(cuid())
  exhibitId   String
  locale      String
  name        String
  /// Eyebrow tag chip rendered on the Collection card and overlay header.
  tag         String?
  /// Long editorial paragraph rendered in the Detail overlay.
  story       String? @db.Text
  description String? @db.Text
  exhibit     Exhibit @relation(fields: [exhibitId], references: [id], onDelete: Cascade)

  @@unique([exhibitId, locale])
}

// ==================== LANDING CONTENT ====================
// Per-locale overrides for static narrative strings on the public landing.
// The site falls back to messages/{locale}.json when a key is missing here.

model LandingContent {
  id        String   @id @default(cuid())
  key       String
  locale    String
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

// ==================== QUIZ ====================

model QuizQuestion {
  id            String                    @id @default(cuid())
  exhibitId     String
  /// "choice" | "text"
  type          String
  order         Int                       @default(0)
  /// For "choice": 0-based index of the correct option.
  correctIndex  Int?
  /// For "text": list of accepted lowercased answers.
  accept        String[]
  exhibit       Exhibit                   @relation(fields: [exhibitId], references: [id], onDelete: Cascade)
  translations  QuizQuestionTranslation[]
}

model QuizQuestionTranslation {
  id         String       @id @default(cuid())
  questionId String
  locale     String
  q          String       @db.Text
  /// For "choice": localized option labels in display order.
  options    String[]
  /// For "text": canonical localized answer label shown in feedback when wrong.
  answerText String?
  explain    String       @db.Text
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, locale])
}

model ExhibitImage {
  id        String  @id @default(cuid())
  exhibitId String
  url       String
  alt       String?
  order     Int     @default(0)
  exhibit   Exhibit @relation(fields: [exhibitId], references: [id], onDelete: Cascade)
}

// ==================== POSTS / NEWS ====================

model Post {
  id           String            @id @default(cuid())
  slug         String            @unique
  coverImage   String?
  published    Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  translations PostTranslation[]
}

model PostTranslation {
  id      String  @id @default(cuid())
  postId  String
  locale  String
  title   String
  excerpt String? @db.Text
  content String? @db.Text
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

// ==================== GALLERY ====================

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ==================== SURVEYS ====================

model Survey {
  id           String              @id @default(cuid())
  exhibitId    String?
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  exhibit      Exhibit?            @relation(fields: [exhibitId], references: [id], onDelete: SetNull)
  translations SurveyTranslation[]
  questions    SurveyQuestion[]
  responses    SurveyResponse[]
}

model SurveyTranslation {
  id          String  @id @default(cuid())
  surveyId    String
  locale      String
  title       String
  description String? @db.Text
  survey      Survey  @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, locale])
}

model SurveyQuestion {
  id           String                 @id @default(cuid())
  surveyId     String
  type         String
  order        Int                    @default(0)
  required     Boolean                @default(false)
  survey       Survey                 @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  translations QuestionTranslation[]
  options      QuestionOption[]
  answers      ResponseAnswer[]
}

model QuestionTranslation {
  id         String         @id @default(cuid())
  questionId String
  locale     String
  text       String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, locale])
}

model QuestionOption {
  id           String              @id @default(cuid())
  questionId   String
  order        Int                 @default(0)
  question     SurveyQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  translations OptionTranslation[]
  answers      ResponseAnswer[]
}

model OptionTranslation {
  id       String         @id @default(cuid())
  optionId String
  locale   String
  text     String
  option   QuestionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, locale])
}

model SurveyResponse {
  id        String           @id @default(cuid())
  surveyId  String
  exhibitId String?
  sessionId String
  locale    String
  createdAt DateTime         @default(now())
  survey    Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  exhibit   Exhibit?         @relation(fields: [exhibitId], references: [id], onDelete: SetNull)
  answers   ResponseAnswer[]
}

model ResponseAnswer {
  id          String          @id @default(cuid())
  responseId  String
  questionId  String
  optionId    String?
  textValue   String?         @db.Text
  ratingValue Int?
  response    SurveyResponse  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question    SurveyQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option      QuestionOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
}

// ==================== VISITOR INFO ====================

model VisitorInfo {
  id          String  @id @default(cuid())
  locale      String  @unique
  hours       String? @db.Text
  ticketPrices String? @db.Text
  address     String?
  phone       String?
  email       String?
  mapEmbedUrl String?
}

// ==================== SITE SETTINGS ====================

model SiteSettings {
  id              String  @id @default(cuid())
  locale          String  @unique
  siteName        String?
  siteDescription String? @db.Text
  heroTitle       String?
  heroSubtitle    String?
  heroImage       String?
  aboutText       String? @db.Text
}

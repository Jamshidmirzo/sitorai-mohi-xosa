# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/sitorai_mohi_xosa?schema=public"

# Public URL of the deployment — used by NextAuth as the callback base.
# Local: http://localhost:3030
# Production: https://mohixossa.uz
NEXTAUTH_URL="http://localhost:3030"

# Secret used to sign NextAuth JWTs. Generate fresh per environment:
#   openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_run_openssl_rand_base64_32"
AUTH_SECRET="CHANGE_ME_same_as_NEXTAUTH_SECRET"

NODE_ENV="production"
